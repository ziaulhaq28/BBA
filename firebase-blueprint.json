{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "Information about a registered user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "inquiries": {
      "title": "Consultation Inquiry",
      "description": "Data submitted via the consultation form.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "whatsapp": { "type": "string" },
        "topic": { "type": "string" },
        "message": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["new", "processed", "replied"] }
      },
      "required": ["name", "whatsapp", "topic"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profiles keyed by UID."
    },
    "/inquiries/{inquiryId}": {
      "schema": "inquiries",
      "description": "Stored inquiries from the contact form."
    }
  }
}
